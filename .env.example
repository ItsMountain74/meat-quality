APP_NAME=Meat-Quality
APP_ENV=local
APP_KEY=base64:mgl5AgM6sWOJFSPHIt2UjZC5rj8eyycqPkknFj7YAPU=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://meat-quality.test/

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meatscan
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# MeatScan detector
# Supported: roboflow_universe, openai_vision, mock
MEATSCAN_DETECTOR=roboflow_workflow

# Roboflow Workflows (Serverless)
ROBOFLOW_API_KEY="jQiQriizGnTx3FePstJH"
ROBOFLOW_WORKSPACE="omars-workspace-zr1kk"
ROBOFLOW_WORKFLOW="detect-and-classify"
ROBOFLOW_IMAGE_INPUT_TYPE=base64
# If your workflow requires classes for SAM/segmentation steps:
ROBOFLOW_CLASSES=meat
# Supported: string, list
ROBOFLOW_CLASSES_FORMAT=string
# Optional mapping from your workflow output labels to MeatScan labels
# Example: ROBOFLOW_LABEL_MAP_JSON={"Fresh":"fresh","Spoiled":"spoiled","Unknown":"uncertain"}
ROBOFLOW_LABEL_MAP_JSON=[]
# Example extra inputs your workflow may require (JSON object string)
# ROBOFLOW_WORKFLOW_EXTRA_INPUTS_JSON={"classes":"fresh,spoiled,uncertain"}
ROBOFLOW_WORKFLOW_ENDPOINT_BASE=https://serverless.roboflow.com
ROBOFLOW_TIMEOUT=45
ROBOFLOW_MAX_IMAGE_BYTES=3000000

# Roboflow Universe (Hosted Inference - Classification) - optional alternative
ROBOFLOW_MODEL="meat-quality-classification"
ROBOFLOW_VERSION=1
ROBOFLOW_ENDPOINT_BASE=https://classify.roboflow.com
